{
  "qa": {
    "emoji": "💡", "description": "quick code & general questions",
    "mode": "ephemeral",
    "access": { "roles": ["*"] },
    "runtime": { "cwd": "~", "model": "claude-haiku-4-5", "allowedTools": ["Read", "Grep", "Glob"] }
  },
  "research": {
    "emoji": "🔬", "description": "web research, deep multi-source dives",
    "mode": "persistent",
    "access": { "roles": ["dev", "admin"], "users": [], "consultableBy": ["assistant", "help"] },
    "runtime": { "cwd": "~", "model": "claude-sonnet-4-6" }
  },
  "assistant": {
    "emoji": "🤖",
    "description": "persistent assistant — handles webhooks, schedules, commands; can post cards",
    "mode": "persistent",
    "access": { "roles": ["<ROLE>"], "users": ["<USER_ID>"] },
    "runtime": {
      "cwd": "<path to a checkout the agent can read>",
      "model": "claude-sonnet-4-6",
      "appendSystemPrompt": "<optional extra system prompt for this agent>",
      "claudeArgs": ["--add-dir", "<extra dir>"],
      "sessionGovernor": { "enabled": true, "softPct": 0.75, "hardPct": 0.9, "strategy": "restart" },
      "maxQueueDepth": 8
    }
  },
  "worker": {
    "emoji": "🚀",
    "description": "ephemeral worker — spawned per spawnTrigger to run a one-shot task",
    "mode": "ephemeral",
    "access": { "roles": [], "users": ["<USER_ID>"] },
    "runtime": {
      "cwd": "<working dir for the task>",
      "model": "claude-opus-4-8",
      "allowedTools": ["Bash", "Read", "Edit", "Write", "Grep", "Glob"],
      "appendSystemPrompt": "<optional extra system prompt for this worker>",
      "overseer": { "enabled": true, "maxIterations": 4, "maxWallclockMs": 600000 }
    }
  },
  "help": {
    "emoji": "💁",
    "description": "ongoing help conversations — keeps context, remembers across chats; use for follow-ups and anything multi-step",
    "mode": "persistent",
    "access": { "roles": ["*"] },
    "runtime": {
      "cwd": "~",
      "model": "claude-sonnet-4-6",
      "useMemory": true,
      "injectContext": "onSwitch",
      "pool": { "min": 1, "max": 3, "scaleUpQueue": 2, "scaleUpSustainMs": 30000, "replicaIdleMs": 600000 }
    }
  },
  "help-quick": {
    "emoji": "⚡",
    "description": "fast one-off questions that need no follow-up — quick-fire Q&A, spawned fresh per question",
    "mode": "ephemeral",
    "access": { "roles": ["*"] },
    "runtime": {
      "cwd": "~",
      "model": "claude-haiku-4-5",
      "allowedTools": ["Read", "Grep", "Glob"],
      "useMemory": true,
      "injectContext": "always"
    }
  }
}
