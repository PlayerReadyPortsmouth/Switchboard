{
  "botTokenEnv": "DISCORD_BOT_TOKEN",
  "guildIds": [],
  "socketPath": "~/.switchboard/hub.sock",
  "stateDir": "~/.switchboard",
  "routerModel": "claude-haiku-4-5",
  "switchThreshold": 0.7,
  "defaultAgent": "qa",
  "ephemeralTimeoutMs": 120000,
  "tagStyle": "prefix",
  "chatKeyScope": "user",
  "memoryDir": "~/.switchboard/memory",
  "contextCacheSize": 20,
  "distillIdleMs": 600000,
  "librarianModel": "claude-haiku-4-5",
  "distillerModel": "claude-sonnet-4-6",
  "overseerModel": "claude-haiku-4-5",
  "contextWindows": { "default": 200000 },
  "statusChannelId": "<channel id for the live status board, or omit to disable>",
  "statusRefreshMs": 15000,
  "metricsPort": 9090,
  "webPort": 8080,
  "memory": {
    "index": "local",
    "embedder": "local",
    "qdrant": {
      "url": "http://localhost:6333",
      "apiKeyEnv": "QDRANT_API_KEY",
      "collection": "switchboard_memory"
    },
    "openai": {
      "baseUrl": "https://api.openai.com/v1",
      "apiKeyEnv": "OPENAI_API_KEY",
      "model": "text-embedding-3-small"
    }
  },
  "gardener": {
    "enabled": false,
    "intervalMs": 21600000,
    "importanceWeight": 0.15,
    "hotSetSize": 3,
    "decayHalfLifeMs": 1209600000,
    "staleAfterMs": 2592000000,
    "archiveAfterMs": 7776000000,
    "scopeBudget": 200
  },
  "deployApproverUserId": "<USER_ID>",
  "webhookPort": 4400,
  "webhooks": [
    {
      "path": "/hooks/example",
      "secretEnv": "MY_WEBHOOK_SECRET",
      "agent": "assistant",
      "channelId": "<channel id>",
      "prefix": "INCOMING"
    }
  ],
  "schedules": [
    {
      "id": "daily-digest",
      "cron": "0 7 * * *",
      "agent": "assistant",
      "channelId": "<channel id>",
      "message": "Post the daily digest."
    },
    {
      "id": "club-checkins",
      "cron": "*/15 8-21 * * *",
      "agent": "assistant",
      "channelId": "<channel id>",
      "message": "Run the 15-minute club check-in sweep."
    },
    {
      "id": "nightly-backlog-sweep",
      "hourUtc": 2,
      "agent": "assistant",
      "channelId": "<channel id>",
      "message": "Sweep the overnight backlog."
    }
  ],
  "commands": [
    {
      "match": "!digest",
      "agent": "assistant",
      "channelId": "<channel id>",
      "message": "Post the digest now.",
      "allowlistOnly": true
    }
  ],
  "directCommands": [
    {
      "match": "!tb status",
      "exec": { "type": "http", "url": "https://api.example.com/status/$1", "secretEnv": "STATUS_TOKEN" },
      "render": "card",
      "cardTitle": "Service status",
      "template": "**{{service}}**: {{state}} — {{detail}}"
    },
    {
      "match": "!tb digest",
      "exec": { "type": "shell", "command": "/opt/scripts/digest.sh $args" },
      "formatAgent": "assistant",
      "template": "Turn this raw digest into a tidy summary for the channel:"
    }
  ],
  "spawnTriggers": [
    {
      "pattern": "SPAWN_WORKER\\s+(\\S+)",
      "agent": "worker",
      "taskTemplate": "Handle task $1. Job id: $jobId.",
      "setupCommand": "git worktree add /tmp/$jobId"
    }
  ],
  "outboundWebhooks": [
    {
      "id": "deploy-done",
      "pattern": "DEPLOYED\\s+(\\S+)",
      "url": "https://hooks.example.com/deploy",
      "secretEnv": "OUT_HOOK_SECRET",
      "template": "{\"event\":\"deploy\",\"ref\":\"$1\"}"
    },
    {
      "id": "notify-ops",
      "url": "https://hooks.example.com/ops",
      "secretEnv": "OUT_HOOK_SECRET",
      "requireApproval": true
    },
    {
      "id": "schedule.fired",
      "url": "https://hooks.example.com/events",
      "secretEnv": "OUT_HOOK_SECRET"
    }
  ],
  "outboundAllowedHosts": ["hooks.example.com"],
  "outboundRetries": 3,
  "audit": {
    "enabled": true,
    "kinds": ["route", "exec", "outbound", "access", "session", "approval"],
    "maxBytes": 10485760,
    "keepFiles": 5
  },
  "trace": {
    "enabled": false
  },
  "approvals": {
    "enabled": true,
    "channelId": "<channel id for Approve/Deny cards, or omit to use the effect's origin channel>",
    "approvers": ["<discord user id>"],
    "ttlMs": 3600000
  },
  "peering": {
    "enabled": false,
    "listenPath": "/peer",
    "selfName": "hub-a",
    "selfBaseUrl": "http://127.0.0.1:8787",
    "askTimeoutMs": 300000,
    "mirrorChannelId": null,
    "dedupeWindowMs": 600000,
    "maxClockSkewMs": 120000,
    "ratePerPeerPerMin": 120,
    "notifyRetry": { "maxAttempts": 5, "baseDelayMs": 2000 },
    "peers": [
      { "name": "hub-b", "baseUrl": "http://127.0.0.1:8788", "secretEnv": "PEER_HUB_B_SECRET" }
    ]
  },
  "consult": {
    "enabled": true,
    "timeoutMs": 90000
  },
  "workflow": {
    "enabled": true,
    "stepTimeoutMs": 120000
  },
  "workflows": [
    {
      "id": "ship-feature",
      "description": "research → implement → review, one governed pipeline",
      "steps": [
        { "id": "research", "agent": "research", "prompt": "Research how to {{input}}. Summarise the approach and any gotchas." },
        { "id": "implement", "agent": "assistant", "prompt": "Using this research:\n{{steps.research}}\n\nImplement: {{input}}. Describe what you changed." },
        { "id": "review", "agent": "help", "prompt": "Review this work for correctness:\n{{steps.implement}}\n\nList any issues, or say LGTM." }
      ]
    }
  ],
  "timezone": "Europe/London"
}
