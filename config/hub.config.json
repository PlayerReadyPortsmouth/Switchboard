{
  "botTokenEnv": "DISCORD_BOT_TOKEN",
  "guildIds": [],
  "socketPath": "~/.switchboard/hub.sock",
  "stateDir": "~/.switchboard",
  "routerModel": "claude-haiku-4-5",
  "switchThreshold": 0.7,
  "defaultAgent": "qa",
  "ephemeralTimeoutMs": 120000,
  "tagStyle": "prefix",
  "chatKeyScope": "user",
  "memoryDir": "~/.switchboard/memory",
  "contextCacheSize": 20,
  "distillIdleMs": 600000,
  "librarianModel": "claude-haiku-4-5",
  "distillerModel": "claude-sonnet-4-6",
  "overseerModel": "claude-haiku-4-5",
  "memory": {
    "index": "local",
    "embedder": "local",
    "qdrant": { "url": "http://localhost:6333", "apiKeyEnv": "QDRANT_API_KEY", "collection": "switchboard_memory" },
    "openai": { "baseUrl": "https://api.openai.com/v1", "apiKeyEnv": "OPENAI_API_KEY", "model": "text-embedding-3-small" }
  },
  "gardener": {
    "enabled": false,
    "intervalMs": 21600000,
    "importanceWeight": 0.15,
    "hotSetSize": 3,
    "decayHalfLifeMs": 1209600000,
    "staleAfterMs": 2592000000,
    "archiveAfterMs": 7776000000,
    "scopeBudget": 200
  },
  "deployApproverUserId": "<USER_ID>",
  "webhookPort": 4400,
  "webhooks": [
    {
      "path": "/hooks/example",
      "secretEnv": "MY_WEBHOOK_SECRET",
      "agent": "assistant",
      "channelId": "<channel id>",
      "prefix": "INCOMING"
    }
  ],
  "schedules": [
    {
      "id": "daily-digest",
      "cron": "0 7 * * *",
      "agent": "assistant",
      "channelId": "<channel id>",
      "message": "Post the daily digest."
    },
    {
      "id": "hourly-pulse",
      "cron": "0 * * * *",
      "agent": "assistant",
      "channelId": "<channel id>",
      "message": "Post the hourly pulse."
    },
    {
      "id": "weekday-payroll",
      "cron": "0 9 * * 1-5",
      "agent": "assistant",
      "channelId": "<channel id>",
      "message": "Run the payroll check."
    }
  ],
  "commands": [
    {
      "match": "!digest",
      "agent": "assistant",
      "channelId": "<channel id>",
      "message": "Post the digest now.",
      "allowlistOnly": true
    }
  ],
  "directCommands": [
    {
      "match": "!tb status",
      "exec": { "type": "http", "url": "https://api.example.com/status/$1", "secretEnv": "STATUS_TOKEN" },
      "render": "card",
      "cardTitle": "Service status",
      "template": "**{{service}}**: {{state}} — {{detail}}"
    },
    {
      "match": "!tb digest",
      "exec": { "type": "shell", "command": "/opt/scripts/digest.sh $args" },
      "formatAgent": "assistant",
      "template": "Turn this raw digest into a tidy summary for the channel:"
    }
  ],
  "spawnTriggers": [
    {
      "pattern": "SPAWN_WORKER\\s+(\\S+)",
      "agent": "worker",
      "taskTemplate": "Handle task $1. Job id: $jobId.",
      "setupCommand": "git worktree add /tmp/$jobId"
    }
  ]
}
